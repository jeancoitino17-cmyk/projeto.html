programa {
  funcao inicio() {
    logico somFuncionado 
    logico figurinoCompleto
    
    escreva("O som esta funcionando? ")
    leia(somFuncionado)
    escreva("O figurino esta completo? ")
    leia(figurinoCompleto)
    se(somFuncionado e figurinoCompleto){
       escreva("Palco liberado para Sarumano! Luzes, câmera, ilusão!")
    }senao{
       escreva("Sem som. Realizar apresentação alternativa no salão.")
    }
  }
}


