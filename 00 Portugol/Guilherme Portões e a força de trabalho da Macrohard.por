programa {
  funcao inicio() {
    
    inteiro clt = 15
    inteiro estagiarios = 5
    inteiro pj = 8
    inteiro total 
  // ler variaves de entrada
  escreva("Quantidade de Clts: ")
  leia(clt)

  escreva("Quantidade de estagiarios: ")
  leia(estagiarios)

  escreva("Quantidade de pj: ")
  leia(pj)
  // procesar / e calcular
  total = clt + estagiarios + pj
  //mostrar os resusltados
  escreva("-------------\n")
  escreva("Total de devs " + total)
  }
}
  

