programa {
  funcao inicio() { // Junin e o salário diário
    real salario 
    inteiro dias 
    real salarioDiario

    escreva("Digite seu salário: ")
    leia(salario)
    escreva( "quantos  dias  trabalhou no mês:" ) 
    leia(dias)
    salarioDiario = salario / dias
    escreva ("\npor dia você recebe R$" + salarioDiario)

  }
}
